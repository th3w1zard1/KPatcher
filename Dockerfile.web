# Multi-stage Dockerfile for Andastra Web Integration
# Builds WASM runtime, encrypts it, and packages with ASP.NET backend

# Stage 1: Build WASM with AOT compilation
FROM mcr.microsoft.com/dotnet/sdk:9.0 AS wasm-builder

WORKDIR /src

# Copy project files
COPY src/Andastra/Game.Wasm/*.csproj src/Andastra/Game.Wasm/
COPY src/Andastra/Runtime/Core/*.csproj src/Andastra/Runtime/Core/
COPY src/Andastra/Runtime/Content/*.csproj src/Andastra/Runtime/Content/
COPY src/Andastra/Runtime/Scripting/*.csproj src/Andastra/Runtime/Scripting/
COPY src/Andastra/Runtime/Graphics/Common/*.csproj src/Andastra/Runtime/Graphics/Common/
COPY src/Andastra/Runtime/Graphics/Stride/*.csproj src/Andastra/Runtime/Graphics/Stride/
COPY src/Andastra/Runtime/Games/Common/*.csproj src/Andastra/Runtime/Games/Common/
COPY src/Andastra/Runtime/Games/Odyssey/*.csproj src/Andastra/Runtime/Games/Odyssey/

# Restore dependencies
RUN dotnet restore src/Andastra/Game.Wasm/Andastra.Game.Wasm.csproj

# Copy source code
COPY src/ src/

# Build and publish WASM with AOT
RUN dotnet publish src/Andastra/Game.Wasm/Andastra.Game.Wasm.csproj \
    -c Release \
    -o /app/wasm \
    -r browser-wasm \
    /p:RunAOTCompilation=true \
    /p:PublishTrimmed=true

# Stage 2: Encrypt WASM
FROM mcr.microsoft.com/dotnet/sdk:9.0 AS encryptor

WORKDIR /app

# Copy encryption utilities
COPY src/Andastra/Web/Crypto/*.csproj src/Andastra/Web/Crypto/
RUN dotnet restore src/Andastra/Web/Crypto/Andastra.Web.Crypto.csproj

COPY src/Andastra/Web/Crypto/ src/Andastra/Web/Crypto/

# Copy WASM from previous stage
COPY --from=wasm-builder /app/wasm /app/wasm

# Create encryption tool
RUN cat > /app/encrypt.cs << 'EOF'
using System;
using System.IO;
using Andastra.Web.Crypto;

class Program
{
    static void Main(string[] args)
    {
        var key = WasmEncryption.GenerateKey();
        var wasmPath = "/app/wasm/Andastra.Game.Wasm.wasm";
        var outputPath = "/app/wasm/Andastra.Game.Wasm.wasm.encrypted";
        
        if (!File.Exists(wasmPath))
        {
            Console.WriteLine("ERROR: WASM file not found at " + wasmPath);
            Environment.Exit(1);
        }
        
        Console.WriteLine("Encrypting WASM...");
        WasmEncryption.EncryptWasmFile(wasmPath, outputPath, key);
        
        // Save key for runtime decryption
        File.WriteAllBytes("/app/wasm/master.key", key);
        Console.WriteLine("WASM encrypted successfully");
    }
}
EOF

# Build and run encryption tool
RUN dotnet build src/Andastra/Web/Crypto/Andastra.Web.Crypto.csproj -o /app/crypto && \
    dotnet script /app/encrypt.cs || echo "Note: Encryption step requires actual WASM file"

# Stage 3: Build ASP.NET Backend
FROM mcr.microsoft.com/dotnet/sdk:9.0 AS backend-builder

WORKDIR /src

# Copy project files
COPY src/Andastra/Web/Api/*.csproj src/Andastra/Web/Api/
COPY src/Andastra/Web/Crypto/*.csproj src/Andastra/Web/Crypto/

# Restore dependencies
RUN dotnet restore src/Andastra/Web/Api/Andastra.Web.Api.csproj

# Copy source code
COPY src/Andastra/Web/ src/Andastra/Web/

# Build and publish
RUN dotnet publish src/Andastra/Web/Api/Andastra.Web.Api.csproj \
    -c Release \
    -o /app/backend

# Stage 4: Final runtime image
FROM mcr.microsoft.com/dotnet/aspnet:9.0 AS runtime

WORKDIR /app

# Install nginx for static file serving (optional)
RUN apt-get update && \
    apt-get install -y nginx && \
    rm -rf /var/lib/apt/lists/*

# Copy backend
COPY --from=backend-builder /app/backend ./

# Copy frontend files
COPY src/Andastra/Web/Frontend/html/ ./wwwroot/
COPY src/Andastra/Web/Frontend/css/ ./wwwroot/css/
COPY src/Andastra/Web/Frontend/js/ ./wwwroot/js/

# Copy encrypted WASM
RUN mkdir -p ./wwwroot/wasm
COPY --from=encryptor /app/wasm/*.encrypted ./wwwroot/wasm/ || true
COPY --from=encryptor /app/wasm/*.json ./wwwroot/wasm/ || true

# Set environment variables
ENV ASPNETCORE_URLS=http://+:5000
ENV ASPNETCORE_ENVIRONMENT=Production

# Expose ports
EXPOSE 5000

# Health check
HEALTHCHECK --interval=30s --timeout=3s --start-period=10s --retries=3 \
  CMD curl -f http://localhost:5000/api/version || exit 1

# Run the application
ENTRYPOINT ["dotnet", "Andastra.Web.Api.dll"]
