<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:KPatcher.UI.ViewModels"
        xmlns:ui="clr-namespace:KPatcher.UI.Resources"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:rtb="clr-namespace:AvRichTextBox;assembly=AvRichTextBox"
        mc:Ignorable="d" d:DesignWidth="620" d:DesignHeight="560"
        x:Class="KPatcher.UI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding WindowTitle}"
        Width="620" Height="560"
        MinWidth="520" MinHeight="420">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Resources>
        <!-- Idiomatic log-level colors: error=red, warning=dark golden yellow, verbose=light blue, note=black -->
        <SolidColorBrush x:Key="DebugBrush" Color="#87CEEB"/>
        <SolidColorBrush x:Key="InfoBrush" Color="#000000"/>
        <SolidColorBrush x:Key="WarningBrush" Color="#B8860B"/>
        <SolidColorBrush x:Key="WarningBackgroundBrush" Color="#FFF3E0"/>
        <SolidColorBrush x:Key="ErrorBrush" Color="#DC143C"/>
        <SolidColorBrush x:Key="CriticalBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="CriticalBackgroundBrush" Color="#8B0000"/>
    </Window.Resources>

    <DockPanel>
        <!-- Menu bar -->
        <Menu DockPanel.Dock="Top">
            <!-- Tools Menu -->
            <MenuItem Header="{x:Static ui:UIResources.MenuTools}">
                <MenuItem Header="{x:Static ui:UIResources.ValidateIni}" Command="{Binding ValidateIniCommand}"/>
                <MenuItem Header="{x:Static ui:UIResources.UninstallModRestoreBackup}" Command="{Binding UninstallModCommand}"/>
                <MenuItem Header="{x:Static ui:UIResources.FixPermissionsToFileFolder}" Command="{Binding FixPermissionsCommand}"/>
                <MenuItem Header="{x:Static ui:UIResources.FixIOSCaseSensitivity}" Command="{Binding FixCaseSensitivityCommand}"/>
            </MenuItem>

            <!-- Help Menu (TSLPatcher parity: Help window with FilePatcherDescription) -->
            <MenuItem Header="{x:Static ui:UIResources.MenuHelp}">
                <MenuItem Header="{x:Static ui:UIResources.HelpWindowTitle}" Command="{Binding ShowHelpCommand}"/>
                <MenuItem Header="{x:Static ui:UIResources.DeadlyStream}">
                    <MenuItem Header="{x:Static ui:UIResources.Discord}" Command="{Binding OpenUrlCommand}" CommandParameter="https://discord.gg/nDkHXfc36s"/>
                    <MenuItem Header="{x:Static ui:UIResources.Website}" Command="{Binding OpenUrlCommand}" CommandParameter="https://deadlystream.com"/>
                </MenuItem>
                <MenuItem Header="{x:Static ui:UIResources.KOTORCommunityPortal}">
                    <MenuItem Header="{x:Static ui:UIResources.Discord}" Command="{Binding OpenUrlCommand}" CommandParameter="https://discord.com/invite/kotor"/>
                    <MenuItem Header="{x:Static ui:UIResources.Website}" Command="{Binding OpenUrlCommand}" CommandParameter="https://kotor.neocities.org"/>
                </MenuItem>
                <MenuItem Header="{x:Static ui:UIResources.PCGamingWiki}">
                    <MenuItem Header="{x:Static ui:UIResources.KOTOR1}" Command="{Binding OpenUrlCommand}" CommandParameter="https://www.pcgamingwiki.com/wiki/Star_Wars:_Knights_of_the_Old_Republic"/>
                    <MenuItem Header="{x:Static ui:UIResources.KOTOR2TSL}" Command="{Binding OpenUrlCommand}" CommandParameter="https://www.pcgamingwiki.com/wiki/Star_Wars:_Knights_of_the_Old_Republic_II_-_The_Sith_Lords"/>
                </MenuItem>
            </MenuItem>

            <!-- Language Menu -->
            <MenuItem Header="{x:Static ui:UIResources.MenuLanguage}">
                <MenuItem Header="{x:Static ui:UIResources.LanguageEnglish}" Command="{Binding SetLanguageCommand}" CommandParameter="en"/>
                <MenuItem Header="{x:Static ui:UIResources.LanguageSpanish}" Command="{Binding SetLanguageCommand}" CommandParameter="es"/>
                <MenuItem Header="{x:Static ui:UIResources.LanguageGerman}" Command="{Binding SetLanguageCommand}" CommandParameter="de"/>
                <MenuItem Header="{x:Static ui:UIResources.LanguageFrench}" Command="{Binding SetLanguageCommand}" CommandParameter="fr"/>
                <MenuItem Header="{x:Static ui:UIResources.LanguageRussian}" Command="{Binding SetLanguageCommand}" CommandParameter="ru"/>
                <MenuItem Header="{x:Static ui:UIResources.LanguagePolish}" Command="{Binding SetLanguageCommand}" CommandParameter="pl"/>
            </MenuItem>

            <!-- About menu (separate from Help) -->
            <MenuItem Header="{x:Static ui:UIResources.MenuAbout}">
                <MenuItem Header="{x:Static ui:UIResources.CheckForUpdates}" Command="{Binding CheckUpdatesCommand}"/>
                <MenuItem Header="{x:Static ui:UIResources.KPatcherHome}" Command="{Binding OpenUrlCommand}" CommandParameter="https://deadlystream.com/files/file/2243-kpatcher"/>
                <MenuItem Header="{x:Static ui:UIResources.GitHubSource}" Command="{Binding OpenUrlCommand}" CommandParameter="https://github.com/OldRepublicDevs/KPatcher"/>
            </MenuItem>
        </Menu>

        <!-- Bottom: separator, button row, progress bar -->
        <Border DockPanel.Dock="Bottom"
                BorderBrush="#E8E8E8"
                BorderThickness="0,1,0,0"
                Padding="16,12,16,16"
                Background="#F5F5F5">
            <Grid RowDefinitions="Auto,Auto">
                <!-- Button Row - Exit left, magnifier + Install right -->
                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0"
                            Content="{x:Static ui:UIResources.Exit}"
                            Command="{Binding ExitCommand}"
                            MinWidth="72"
                            Padding="14,6"/>
                    <Button Grid.Column="2"
                            Command="{Binding ToggleConfigurationSummaryCommand}"
                            IsEnabled="{Binding CanShowConfigurationSummary}"
                            Width="28"
                            Height="28"
                            Padding="0"
                            Margin="0,0,6,0"
                            ToolTip.Tip="{x:Static ui:UIResources.ConfigurationSummaryToolTip}">
                        <PathIcon Data="M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L14.71,14L15.5,14.79L14.79,15.5L14,14.71L13.73,14.44C12.59,15.41 11.11,16 9.5,16A6.5,6.5 0 0,1 3,9.5A6.5,6.5 0 0,1 9.5,3M9.5,5C7,5 5,7 5,9.5C5,12 7,14 9.5,14C12,14 14,12 14,9.5C14,7 12,5 9.5,5Z"/>
                    </Button>
                    <Button Grid.Column="3"
                            Classes="primary"
                            Content="{Binding StartPatchingButtonText}"
                            Command="{Binding InstallCommand}"
                            IsEnabled="{Binding CanInstall}"
                            MinWidth="120"
                            Padding="14,6"/>
                </Grid>
                <ProgressBar Grid.Row="1"
                             Value="{Binding ProgressValue}"
                             Maximum="{Binding ProgressMaximum}"
                             Height="8"
                             CornerRadius="4"/>
            </Grid>
        </Border>

        <!-- Main Content: full-width, packed to top -->
        <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="8,6,8,0">
            <!-- Alpha version warning banner -->
            <Border Grid.Row="0"
                    Background="#FFF8E1"
                    BorderBrush="#FFC107"
                    BorderThickness="1"
                    CornerRadius="6"
                    Margin="0,0,0,6"
                    Padding="12,8"
                    IsVisible="{Binding IsAlphaVersion}">
                <TextBlock Text="{x:Static ui:UIResources.AlphaBannerText}"
                           FontWeight="SemiBold"
                           FontSize="12"
                           Foreground="#795548"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"/>
            </Border>

            <!-- Mod selection row (no frame) -->
            <Grid Grid.Row="1"
                  ColumnDefinitions="*,Auto,Auto"
                  Margin="0,0,0,4"
                  IsVisible="{Binding IsModSelectionVisible}">
                <ComboBox Grid.Column="0"
                          ItemsSource="{Binding Namespaces}"
                          SelectedItem="{Binding SelectedNamespace}"
                          PlaceholderText="{x:Static ui:UIResources.PlaceholderSelectMod}"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Center"/>
                <Button Grid.Column="1"
                        Content="{x:Static ui:UIResources.Browse}"
                        Command="{Binding BrowseModCommand}"
                        Margin="6,0,0,0"
                        Padding="8,4"
                        VerticalAlignment="Center"/>
                <Button Grid.Column="2"
                        Content="?"
                        Command="{Binding ShowNamespaceInfoCommand}"
                        Width="26"
                        Margin="4,0,0,0"
                        Padding="0"
                        VerticalAlignment="Center"/>
            </Grid>

            <!-- Game path row (no frame) -->
            <Grid Grid.Row="2"
                  ColumnDefinitions="*,Auto"
                  Margin="0,0,0,6">
                <ComboBox Grid.Column="0"
                          ItemsSource="{Binding GamePaths}"
                          SelectedItem="{Binding SelectedGamePath}"
                          PlaceholderText="{x:Static ui:UIResources.PlaceholderSelectKotor}"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Center"/>
                <Button Grid.Column="1"
                        Content="{x:Static ui:UIResources.Browse}"
                        Command="{Binding BrowseGamePathCommand}"
                        Margin="6,0,0,0"
                        Padding="8,4"
                        VerticalAlignment="Center"/>
            </Grid>

            <!-- Log / output panel: RTF or plain text -->
            <Border Grid.Row="3" Classes="logPanel" Padding="0" MinHeight="120">
                <Grid>
                    <rtb:RichTextBox x:Name="RtfRichTextBox"
                                     IsVisible="{Binding IsRtfContent}"
                                     IsReadOnly="True"
                                     HorizontalAlignment="Stretch"
                                     VerticalAlignment="Stretch"
                                     Margin="0"/>
                    <!-- Log: colored by level (error/warning/note/verbose), selectable and copyable -->
                    <ScrollViewer x:Name="LogScrollViewer"
                                  IsVisible="{Binding IsNotRtfContent}"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto">
                        <rtb:RichTextBox x:Name="LogRichTextBox"
                                         IsReadOnly="True"
                                         HorizontalAlignment="Stretch"
                                         VerticalAlignment="Stretch"
                                         FontFamily="Consolas, 'Cascadia Code', 'Segoe UI', sans-serif"
                                         FontSize="13"
                                         Padding="12,8"
                                         Background="Transparent"
                                         BorderThickness="0"/>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </DockPanel>
</Window>
